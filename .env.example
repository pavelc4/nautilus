# Telegram / auth
TELEGRAM_APP_ID=123456
TELEGRAM_APP_HASH=your_hash
BOT_TOKEN=123456789:AAA...
OWNER_ID=123456789

# Providers
ASTRA_API_URL=http://localhost:3000     # cookies/auth handled entirely by Astra

# Limits & behavior
MAX_FILE_SIZE_MB=2000           # 2GB Telegram hard limit
PROGRESS_EDIT_SECS=3            # min seconds between status-message edits (anti-FLOOD_WAIT)
# MAX_CONCURRENT_JOBS=          # job-level semaphore; unset = clamp(cpus, 1, 4)
